---
import Layout from '../layouts/BlogPost.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout
	title="過去ログ一覧"
	description="エビデンスで組む、最強宅トレに投稿されたすべての記事一覧です。"
>
	<p class="archive-intro">
		当ブログでこれまでに公開されたすべての記事の一覧です。気になる記事をクリックしてお読みください。
	</p>

	<ul class="archive-list">
		{
			posts.map((post) => (
				<li>
					<span class="archive-date">
						<FormattedDate date={post.data.pubDate} />
					</span>
					<a href={`/blog/${post.id}/`} class="archive-title-link">
						{post.data.title}
					</a>
				</li>
			))
		}
	</ul>
</Layout>

<style>
	.archive-intro {
		color: #475569;
		font-size: 0.95rem;
		margin-bottom: 2rem;
		line-height: 1.7;
	}
	.archive-list {
		list-style-type: none;
		padding: 0;
		margin: 2rem 0;
	}
	.archive-list li {
		display: flex;
		gap: 2rem;
		padding: 1rem 0;
		border-bottom: 1px dashed #cbd5e1;
		align-items: center;
	}
	.archive-date {
		font-size: 0.85rem;
		color: #64748b;
		font-weight: 600;
		font-family: 'Montserrat', sans-serif;
		min-width: 100px;
	}
	.archive-title-link {
		font-weight: 700;
		color: var(--accent);
		text-decoration: none;
		line-height: 1.4;
	}
	.archive-title-link:hover {
		color: var(--accent-dark);
		text-decoration: underline;
	}
	@media (max-width: 600px) {
		.archive-list li {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.35rem;
			padding: 0.85rem 0;
		}
		.archive-date {
			min-width: auto;
		}
	}
</style>

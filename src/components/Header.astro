---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">ホーム</HeaderLink>
			<HeaderLink href="/archive">過去ログ</HeaderLink>
			<HeaderLink href="/contact">お問い合わせ</HeaderLink>
			<HeaderLink href="/disclaimer">免責事項・運営者情報</HeaderLink>
			<HeaderLink href="/privacy">プライバシーポリシー</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		margin: 0;
		padding: 0 1.5rem;
		background: rgba(255, 255, 255, 0.8);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid rgba(15, 23, 42, 0.06);
		box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.01);
	}
	h2 {
		margin: 0;
		font-size: 1.15em;
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: #0f172a;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1120px;
		margin: 0 auto;
		height: 4.5rem;
	}
	.internal-links {
		display: flex;
		gap: 1.5rem;
	}
	nav a {
		padding: 0.5rem 0;
		color: #475569;
		font-weight: 500;
		text-decoration: none;
		border-bottom: 2px solid transparent;
		transition: color 0.2s ease, border-color 0.2s ease;
		font-size: 0.95em;
	}
	nav a.active {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}
	nav a:hover {
		color: var(--accent);
	}
	@media (max-width: 720px) {
		header {
			padding: 0 1rem;
		}
		nav {
			height: auto;
			flex-direction: column;
			padding: 1rem 0;
			gap: 0.75rem;
		}
		.internal-links {
			gap: 1rem;
			flex-wrap: wrap;
			justify-content: center;
		}
		nav a {
			font-size: 0.85em;
			padding: 0.25rem 0;
		}
	}
</style>
